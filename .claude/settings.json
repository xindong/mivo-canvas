{
  "xdtMaker": {
    "builtinTools": {}
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "npm run codemap --silent"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "npm run codemap --silent"
          }
        ]
      }
    ]
  }
}
