# MivoCanvas BFF environment variables.
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# See server/lib/config.ts + server/lib/env.ts + server/lib/auth-stub.ts for the
# authoritative readers.

# ─── Bind / dev stub (server/index.ts, server/lib/env.ts, server/lib/auth-stub.ts) ──
MIVO_PORT=8080
# MIVO_PUBLIC=1 标记 public/生产部署:监听 0.0.0.0 + 收紧 feature flag(local-assets/
# eagle 默认关、debug-logs GET fail-closed)+ 强制关 dev 桩。未设=监听 127.0.0.1(本地)。
# MIVO_PUBLIC=1
# dev 桩 /api/auth/me opt-in(本地 dev/e2e 用假登录态)。仅 MIVO_DEV_AUTH_STUB=1 &&
# NODE_ENV!=='production' && MIVO_PUBLIC!=='1' 时开;生产/public 硬关。
# MIVO_DEV_AUTH_STUB=1

# ─── Upstream credentials (server/lib/config.ts) ──────────────────────────────
# 团队共享 key;per-user key 经 X-Mivo-Api-Key / X-Gateway-Key header 注入,不入 bundle。
MIVO_IMAGE_API_KEY=
MIVO_LLM_API_KEY=
MIVO_PLATFORM_KEY=
MIVO_PLATFORM_ENDPOINT=https://aigc.xindong.com
# MIVO_IMAGE_API_BASE=https://llm-proxy.tapsvc.com/v1/images
# MIVO_LLM_API_BASE=https://llm-proxy.tapsvc.com/v1

# ─── Local assets / Eagle (server/routes/local-assets.ts, eagle.ts) ───────────
MIVO_ASSET_DIR=~/Desktop/Images
MIVO_EAGLE_API_URL=http://127.0.0.1:41595
# public 模式下 local-assets / eagle 默认关(404);显式 =1 才开。
# MIVO_ENABLE_LOCAL_ASSETS=1
# MIVO_ENABLE_EAGLE_PROXY=1

# ─── Debug logs (server/routes/debug-logs.ts + server/lib/debug-records.ts) ───
# JSONL 按日文件 <date>.jsonl;需挂持久卷,否则容器重启后远端 debug 日志丢失。
# MIVO_DEBUG_LOG_DIR=<cwd>/data/debug-logs
# public 模式下 GET 默认 403;设了才允许读报表(header x-mivo-debug-token 或 query ?token=)。
# MIVO_DEBUG_VIEW_TOKEN=

# ─ 同源放行(034b46c 起生产必配其一,否则同源 POST 全 403)────────────────────
# 生产 debug-logs POST 同源放行需可信外部 origin(防 http Origin 冒充 https 同源)。
# 优先级:MIVO_PUBLIC_ORIGIN > MIVO_DEBUG_TRUST_XFF=1 > 都无则 fail-closed(全 403)。
#
# 方案 A(推荐):固定 canonical origin。直连/已知部署显式配完整 origin。
#   生产同源浏览器 POST 默认放行;跨域仍需 MIVO_DEBUG_ALLOWED_ORIGINS。
#   非空但畸形(非 http(s)/含 path/query/userinfo)→ fail-closed,不降级 XFF。
# MIVO_PUBLIC_ORIGIN=https://<canonical-host>
#
# 方案 B(仅网关 strip 客户端 XFF/XFP + 网络隔离 BFF 时):信任受信 X-Forwarded-Proto。
#   XFP 必须单值 http 或 https(多值如 "https,http" → fail-closed);Host 头取 host:port。
#   必须确认网关 strip 客户端自带 XFF/XFP,否则客户端可伪造 scheme 绕过同源判定。
# MIVO_DEBUG_TRUST_XFF=1

# ─ 跨域 allowlist(生产跨域 POST 必配;同源无需)──────────────────────────────
# 逗号分隔的序列化 origin;归一匹配(大小写/默认端口对称,http:80==http)。
# 生产无 localhost 兜底;未配 + 跨域 → 403。
# MIVO_DEBUG_ALLOWED_ORIGINS=https://app.example,https://staging.example

# ─ 磁盘 quota / retention(防 JSONL 无限增长;append 前惰性 sweep + quota 校验)──────
# 过期 .jsonl 删除(日期早于 today - retentionDays);默认 7 天。
# MIVO_DEBUG_RETENTION_DAYS=7
# log 目录所有 .jsonl 总字节数上限;超限(used+incoming>quota)→ 413;0=禁用 quota。
# MIVO_DEBUG_DISK_QUOTA_MB=512

# ─ 每 IP rate limit(in-memory,单进程,重启清空)──────────────────────────────
# 每 IP 每分钟 POST 上限;默认 60。rate key 默认 socket remote addr(非客户端可控);
# MIVO_DEBUG_TRUST_XFF=1 时改取 XFF 首项(网关后共享网关 IP,可接受)。
# MIVO_DEBUG_POST_RATE_LIMIT=60
# bucket 数上限(防内存无界增长);达上限淘汰 oldest;默认 4096。
# MIVO_DEBUG_RATE_MAX_BUCKETS=4096

# ─── G2.1 严格 SSO (server/lib/owner.ts; runbook: docs/runbook/g21-strict-sso-runbook.md) ──
# ⚠️ MIVO_SSO_STRICT=1 严禁先于 G2.2 owner 迁移翻开!strict 下 resolveActor 返回 SSO username
# (无指纹回退),legacy 形态(ownerId=指纹,sha256[:16] hex)存量数据对 SSO 用户不可见。启动 gate
# (assertStrictOwnerMigrationComplete)机械检测三域(persist + permissions + assets)legacy owner 行数,
# 任一域 >0 且 strict=1 → 拒绝启动 exit 1;任一域 detector 缺失(PG G2.2 前)→ fail-closed 拒启动。
# 翻 strict 前必须先跑 G2.2 迁移(指纹→username),见 runbook §owner-migration gate + §真实网关验收。
# MIVO_SSO_STRICT=1
# 网关注入的共享密钥(生产必设);BFF 据此校验 x-mivo-gateway-secret header 证明网关注入身份头。
# 最小长度建议 ≥32 字节高熵;定期轮换;绝不入日志/错误响应。信任根评估见 runbook §静态共享 secret 信任根。
# MIVO_GATEWAY_SECRET=
# 严格模式下的本地开发通道(三重保险:MIVO_DEV_MODE opt-in + MIVO_PUBLIC=1 恒 false +
# NODE_ENV 正向枚举仅 development/test 放行)。生产/public/staging/空 NODE_ENV 下恒 false → 401,绝不冒充。
# MIVO_DEV_MODE=1
