# MivoCanvas BFF environment variables.
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# See server/lib/config.ts + server/lib/env.ts + server/lib/auth-stub.ts for the
# authoritative readers.

# ─── Bind / dev stub (server/index.ts, server/lib/env.ts, server/lib/auth-stub.ts) ──
MIVO_PORT=8080
# MIVO_PUBLIC=1 标记 public/生产部署:监听 0.0.0.0 + 收紧 feature flag(local-assets/
# eagle 默认关、debug-logs GET fail-closed)+ 强制关 dev 桩。未设=监听 127.0.0.1(本地)。
# MIVO_PUBLIC=1
# dev 桩 /api/auth/me opt-in(本地 dev/e2e 用假登录态)。仅 MIVO_DEV_AUTH_STUB=1 &&
# NODE_ENV!=='production' && MIVO_PUBLIC!=='1' 时开;生产/public 硬关。
# MIVO_DEV_AUTH_STUB=1

# ─── Upstream credentials (server/lib/config.ts) ──────────────────────────────
# 团队共享 key;per-user key 经 X-Mivo-Api-Key / X-Gateway-Key header 注入,不入 bundle。
MIVO_IMAGE_API_KEY=
MIVO_LLM_API_KEY=
MIVO_PLATFORM_KEY=
MIVO_PLATFORM_ENDPOINT=https://aigc.xindong.com
# MIVO_IMAGE_API_BASE=https://llm-proxy.tapsvc.com/v1/images
# MIVO_LLM_API_BASE=https://llm-proxy.tapsvc.com/v1

# ─── Local assets / Eagle (server/routes/local-assets.ts, eagle.ts) ───────────
MIVO_ASSET_DIR=~/Desktop/Images
MIVO_EAGLE_API_URL=http://127.0.0.1:41595
# public 模式下 local-assets / eagle 默认关(404);显式 =1 才开。
# MIVO_ENABLE_LOCAL_ASSETS=1
# MIVO_ENABLE_EAGLE_PROXY=1

# ─── Debug logs (server/routes/debug-logs.ts) ─────────────────────────────────
# MIVO_DEBUG_LOG_DIR=<cwd>/data/debug-logs
# MIVO_DEBUG_VIEW_TOKEN=       # public 模式下 GET 默认 403;设了才允许读报表

# ─── Persist backend + PG connection (server/persist/pgConfig.ts, pgBackend.ts) ──
# T1.3:默认 memory(生产零变化);MIVO_PERSIST_BACKEND=pg 启用 PG 后端(灰度)。
# PG 启用时 MIVO_PG_PASSWORD 必填(缺则 BFF 启动 fail visibly,不静默降级 memory)。
# 生产连接参数由 ecosystem.config.cjs env 块固定;密码不入库,由 deploy.sh 从
# ops/postgres/.env 注入。详见 docs/runbook/p0.3-runtime-hardening.md §连接预算。
# MIVO_PERSIST_BACKEND=pg
# MIVO_PG_HOST=127.0.0.1
# MIVO_PG_PORT=55442          # 共享机 5432 被占,走 55442(见 t1.1 runbook §0.1)
# MIVO_PG_DB=mivocanvas
# MIVO_PG_USER=mivo
# MIVO_PG_PASSWORD=           # 必填(PG 启用时);真实值不入库
# P0.3 连接预算(pg Pool):
# MIVO_PG_MAX_CONNECTIONS=10          # 池上限(单实例保守;多实例时 Σ ≤ PG max_connections 70%)
# MIVO_PG_IDLE_TIMEOUT_MS=30000       # 空闲连接超时(ms),0=不超时
# MIVO_PG_CONNECTION_TIMEOUT_MS=5000  # 池满排队等待超时(ms),超时即抛(fail fast)

# ─── Asset store (server/lib/assetStore.ts, P0.3 固定 asset dir) ──────────────
# 内容寻址 asset 存储(contentHash sha256 hex)。默认 ~/.mivo-canvas/assets(仓库外,
# 不漂移到 git 工作树);生产用 ecosystem.config.cjs 固定到持久卷:
#   MIVO_ASSET_STORE_DIR=/AIGC_Group/mivo-canvas-data/assets
# MIVO_ENABLE_ASSET_SERVICE=1 才挂载 POST/GET /api/assets(默认关,P1.4)。
# MIVO_ENABLE_ASSET_SERVICE=1
# MIVO_ASSET_STORE_DIR=/AIGC_Group/mivo-canvas-data/assets
