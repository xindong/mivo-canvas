# MivoCanvas BFF environment variables.
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# See server/lib/config.ts + server/lib/authConfig.ts for the authoritative readers.

# ─── Existing BFF config (server/lib/config.ts, env.ts) ──────────────────────
MIVO_PORT=8080
# Bind 0.0.0.0 in public deployments (requires an access gate — see below).
# MIVO_PUBLIC=1
# MIVO_BFF_TOKEN=              # legacy single-token gate (Bearer/Basic/X-Mivo-Bff-Token). Optional — JWT auth (below) is the new primary.

# Upstream mivo platform + llm-proxy credentials (team-shared keys; per-user keys are E2's F6).
MIVO_IMAGE_API_KEY=
MIVO_LLM_API_KEY=
MIVO_PLATFORM_KEY=
MIVO_PLATFORM_ENDPOINT=https://aigc.xindong.com
# MIVO_IMAGE_API_BASE=https://llm-proxy.tapsvc.com/v1/images
# MIVO_LLM_API_BASE=https://llm-proxy.tapsvc.com/v1

# ─── feat/auth-feishu-login (E1 · 鉴权骨干, A2 身份依赖 maker server) ────────
# Share JWT_SECRET with maker server (same base64 value as maker's JWT_SECRET env).
# When set, the access gate verifies maker-issued HS256 JWTs from the mivo_auth
# httpOnly cookie. Unset → gate is no-op unless MIVO_BFF_TOKEN is set (local dev).
JWT_SECRET=
# maker server base URL — MivoCanvas BFF proxies /api/auth/login, /api/auth/dev-login,
# /api/auth/logout, and /api/user/me here. E.g. http://localhost:3333 (dev maker).
MAKER_SERVER_URL=
# Feishu App ID (the SAME app maker uses — maker holds the client_secret, MivoCanvas only
# builds the authorize URL with this App ID).
MIVO_FEISHU_APP_ID=
# OAuth scope requested at authorize. Default is the identity minimum; user_info returns
# open_id/name/avatar by default, email needs the email scope. Override only if you need more.
# MIVO_FEISHU_SCOPE=contact:user.email:readonly
# BFF OAuth callback absolute URL. MUST be registered in the Feishu app console Redirect URLs
# whitelist AND in maker's WEB_OAUTH_REDIRECT_ALLOWLIST (feat/web-client-auth). Required in prod
# (behind proxy); local dev auto-derives from request origin if unset.
# MIVO_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback
# DEV-only: enables POST /api/auth/dev-login (mirrors maker dev-login; maker must also set
# XDT_DEV_AUTH_ENABLED=1). NEVER set in production.
# MIVO_DEV_AUTH_ENABLED=1
# Cookie Secure flag. Defaults to MIVO_PUBLIC (prod → secure, local → not). Override for
# HTTP localhost dev with auth: MIVO_COOKIE_SECURE=0
# MIVO_COOKIE_SECURE=1
