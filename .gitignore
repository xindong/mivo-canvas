# Bench: large fixtures (5k+ nodes) and one-off verification baselines are
# generated on-demand (npm run bench:fixtures / bench:collect); only small
# committed fixtures (100/500/1000) are tracked for reproducibility.
bench/fixtures/bench-dom-mixed-5000.json
bench/fixtures/bench-dom-mixed-10000.json
bench/fixtures/bench-dom-mixed-20000.json
bench/fixtures/bench-dom-mixed-50000.json
bench/baselines/verify-*.json
# PR-C drag-perf BEFORE/AFTER comparison JSONs (local measurement artifacts, not for git)
bench-results/

# 0b spike bench baselines (spike 产物,数据见 docs/decisions/leafer-0b-spike-*.md)
bench/baselines/0b-*.json
bench/baselines/.0b-*.log

