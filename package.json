{
  "name": "mivo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "bench:fixtures": "node scripts/bench/generate-fixtures.mjs",
    "bench:collect": "node scripts/bench/collect.mjs",
    "visual:diff": "node scripts/visual-diff.mjs",
    "visual:diff:shell": "node scripts/visual-shell-baselines.mjs",
    "debug:server": "node scripts/debug-log-server.mjs",
    "test:unit": "vitest run",
    "test:bench": "vitest run --config vitest.bench.config.ts",
    "verify:logging": "node scripts/verify-debug-logging.mjs",
    "test:shell": "bash ops/postgres/test-asset-verify.sh && bash ops/postgres/test-restore-drill-matrix.sh",
    "test:e2e": "npm run test:e2e:dev",
    "test:e2e:dev": "node scripts/e2e-runner.mjs --topology=dev",
    "test:e2e:prod:subset": "VITE_MIVO_PERSIST=local npm run build && node scripts/e2e-runner.mjs --topology=prod --scenario=debug,canvas-interactions,chat-generation,mask,mask-reflow,variations-annotation",
    "test:e2e:gated:unauthorized": "node scripts/e2e-gated-check.mjs --mode=unauthorized",
    "test:e2e:gated:authorized": "node scripts/e2e-gated-check.mjs --mode=authorized",
    "test:e2e:prod:full": "VITE_MIVO_PERSIST=local npm run build && node scripts/e2e-runner.mjs --topology=prod",
    "test:e2e:prod": "VITE_MIVO_PERSIST=local npm run build && node scripts/e2e-runner.mjs --topology=prod",
    "start:server": "tsx server/index.ts",
    "contract:diff": "node scripts/contract-diff.mjs",
    "codemap": "node scripts/codemap.mjs",
    "preflight": "tsc -b && npm run lint && npm run verify:logging && node scripts/ci/structure-guard.mjs && npm run test:unit && npm run test:shell",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@leafer-in/editor": "^2.1.7",
    "@leafer-in/view": "^2.1.7",
    "hono": "^4.12.27",
    "kysely": "^0.29.3",
    "leafer-ui": "^2.1.7",
    "lucide-react": "^1.21.0",
    "perfect-freehand": "^1.2.3",
    "pg": "^8.22.0",
    "pixi.js": "^8.19.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "yjs": "^13.6.31"
  }
}
